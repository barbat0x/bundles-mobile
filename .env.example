# Copier vers .env et renseigner (jamais committer de secrets serveur — seulement clés publiques Expo).

EXPO_PUBLIC_THIRDWEB_CLIENT_ID=
EXPO_PUBLIC_API_WS_ENDPOINT=wss://api.bundles.fi/ws/
EXPO_PUBLIC_GRAPH_API_KEY=
EXPO_PUBLIC_RPC_FALLBACK_URL=https://0xrpc.io/eth
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_TRANSAK_API_KEY=
# thirdweb Pay fiat — "true" = isTestMode (Transak staging / cartes test). Jamais true en prod.
EXPO_PUBLIC_THIRDWEB_PAY_TEST_MODE=false
# Optionnel — pays on-ramp ISO2 (ex. FR). Si absent, dérivé du locale (fr-FR → FR). Sans pays, le bridge thirdweb défaut souvent sur US (VPN / IP).
# EXPO_PUBLIC_ONRAMP_COUNTRY=FR
# Optionnel — fallback prix (PLAN §6.5.1)
EXPO_PUBLIC_ALCHEMY_API_KEY=
# Dev only — bypass portfolio auth gate to preview UI locally without wallet.
# EXPO_PUBLIC_DEV_BYPASS_PORTFOLIO_AUTH=false
