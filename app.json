{
  "expo": {
    "name": "bundles.fi",
    "slug": "bundles-fi-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bundlesfi",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F4F6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fi.bundles.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F3F4F6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "fi.bundles.mobile",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@sentry/react-native",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-image",
      "expo-localization",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false,
      "url": ""
    },
    "extra": {
      "EXPO_PUBLIC_API_WS_ENDPOINT": "wss://api.bundles.fi/ws/",
      "EXPO_PUBLIC_RPC_FALLBACK_URL": "https://0xrpc.io/eth",
      "EXPO_PUBLIC_MEDIA_ORIGIN": "https://media.bundles.fi"
    }
  }
}
